# Zkopíruj jako `keystore.properties` a vyplň podle vlastního keystore.
# `keystore.properties` ani složku `keystore/` NIKDY necommituj.
#
# Pro debug build keystore není potřeba — Gradle podepíše defaultním debug klíčem.
# Pro release build (assembleRelease) musí keystore.properties existovat.

storeFile=keystore/release-key.jks
storePassword=CHANGE_ME
keyAlias=zeddihub-gearos
keyPassword=CHANGE_ME
